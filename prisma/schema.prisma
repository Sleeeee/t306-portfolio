generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model users {
  id         Int      @id @default(autoincrement())
  created_at DateTime @default(now())
  email      String   @unique
  username   String
  password   String
}

model labels {
  id           Int                 @id @default(autoincrement())
  name         String
  color        String
  activities   activity_labels[]
  technologies technology_labels[]
}

model technologies {
  id          Int                 @id @default(autoincrement())
  name        String
  mastery     Int
  description String?
  image       String?
  labels      technology_labels[]
}

model activities {
  id          Int               @id @default(autoincrement())
  date        DateTime          @default(now())
  name        String
  description String?
  image       String?
  labels      activity_labels[]
  time_valued Int
  time_real   Int
  proof       String?
}

model technology_labels {
  id            Int          @id @default(autoincrement())
  label_id      Int
  technology_id Int
  label         labels       @relation(fields: [label_id], references: [id], onDelete: Cascade)
  technology    technologies @relation(fields: [technology_id], references: [id], onDelete: Cascade)
}

model activity_labels {
  id          Int        @id @default(autoincrement())
  label_id    Int
  activity_id Int
  activity    activities @relation(fields: [activity_id], references: [id], onDelete: Cascade)
  label       labels     @relation(fields: [label_id], references: [id], onDelete: Cascade)
}
